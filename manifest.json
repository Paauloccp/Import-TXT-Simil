{
  "manifest_version": 3,
  "name": "SIMIL CAIXA - Importar OS TXT/PDF",
  "version": "1.0.0",
  "description": "Lê o TXT/PDF da OS e preenche os campos iniciais no SIMIL.",
  "content_scripts": [
    {
      "matches": [
        "https://simil.caixa.gov.br/*",
        "https://www.simil.caixa.gov.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
